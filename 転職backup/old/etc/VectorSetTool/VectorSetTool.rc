    EDITTEXT        IDC_EDIT_MOVE_Y,32,47,45,15,ES_AUTOHSCROLL
    EDITTEXT        IDC_EDIT_MOVE_Z,32,71,45,15,ES_AUTOHSCROLL
    PUSHBUTTON      "移動",IDC_BUTTON_MOVE,87,21,50,15
    GROUPBOX        "オフセット移動",IDC_STATIC,7,101,145,90
    PUSHBUTTON      "↑",IDC_BUTTON_UP,42,117,20,20
    PUSHBUTTON      "↓",IDC_BUTTON_DOWN,42,157,20,20
    PUSHBUTTON      "←",IDC_BUTTON_LEFT,17,137,20,20
    PUSHBUTTON      "→",IDC_BUTTON_RIGHT,67,137,20,20
    GROUPBOX        "オフセット値",IDC_STATIC,97,117,45,55
    EDITTEXT        IDC_EDIT_OFFSET,102,137,35,15,ES_AUTOHSCROLL
    PUSHBUTTON      "デフォルト",IDC_BUTTON_DEFAULT,87,57,50,14
    GROUPBOX        "ポイント",IDC_STATIC,7,197,145,28
    PUSHBUTTON      "ポイントセット",IDC_BUTTON_SET_POINT,33,208,85,12
    GROUPBOX        "オブジェクト",IDC_STATIC,7,235,145,36
    COMBOBOX        IDC_COMBO_OBJECT,15,250,50,43,CBS_DROPDOWN | CBS_SORT | 
