IDR_VECTORTYPE          ICON    DISCARDABLE     "res\\VectorSetToolDoc.ico"

/////////////////////////////////////////////////////////////////////////////
//
// Menu
//

IDR_MAINFRAME MENU PRELOAD DISCARDABLE 
BEGIN
    POPUP "ﾌｧｲﾙ(&F)"
    BEGIN
        MENUITEM "Xファイルを開く",             ID_FILE_OPEN
        MENUITEM SEPARATOR
        MENUITEM "完成ファイルを保存(&S)",      ID_FILE_SAVE
        MENUITEM SEPARATOR
        MENUITEM "途中セーブ",                  AFX_ID_FILE_SAVE_EX
        MENUITEM "つづきからはじめる",          AFX_ID_FILE_LOAD_EX
        MENUITEM SEPARATOR
        MENUITEM "ｱﾌﾟﾘｹｰｼｮﾝの終了(&X)",         ID_APP_EXIT
    END
    POPUP "モード"
    BEGIN
        MENUITEM "ポイント設定(&N)",            AFX_ID_EDIT_POINT
        MENUITEM "ポイント修正(&C)",            AFX_ID_CHANGE_POINT
        MENUITEM "ポイント削除(&D)",            AFX_ID_DELETE_POINT
        MENUITEM "オブジェクト配置",            AFX_ID_SET_OBJECT_POINT
        MENUITEM "オブジェクト修正",            AFX_ID_CHANGE_OBJECT_POINT
        MENUITEM "オブジェクト削除",            AFX_ID_DELETE_OBJECT_POINT
    END
    POPUP "オブジェクト"
    BEGIN
        MENUITEM "風船",                        AFX_ID_OBJECT_1
        MENUITEM "ドラム缶",                    AFX_ID_OBJECT_2
    END
    POPUP "平行スナップ"
    BEGIN
        MENUITEM "スナップON",                  AFX_ID_SNAP_ON
        MENUITEM "スナップOFF",                 AFX_ID_SNAP_OFF
    END
    POPUP "ﾍﾙﾌﾟ(&H)"
    BEGIN
        MENUITEM "VectorSetTool のﾊﾞｰｼﾞｮﾝ情報(&A)...", ID_APP_ABOUT
    END
END


/////////////////////////////////////////////////////////////////////////////
//
// Accelerator
//

IDR_MAINFRAME ACCELERATORS PRELOAD MOVEABLE PURE 
BEGIN
    "N",            ID_FILE_NEW,            VIRTKEY, CONTROL
    "O",            ID_FILE_OPEN,           VIRTKEY, CONTROL
    "S",            ID_FILE_SAVE,           VIRTKEY, CONTROL
    "Z",            ID_EDIT_UNDO,           VIRTKEY, CONTROL
    "X",            ID_EDIT_CUT,            VIRTKEY, CONTROL
    "C",            ID_EDIT_COPY,           VIRTKEY, CONTROL
    "V",            ID_EDIT_PASTE,          VIRTKEY, CONTROL
    VK_BACK,        ID_EDIT_UNDO,           VIRTKEY, ALT
    VK_DELETE,      ID_EDIT_CUT,            VIRTKEY, SHIFT
    VK_INSERT,      ID_EDIT_COPY,           VIRTKEY, CONTROL
    VK_INSERT,      ID_EDIT_PASTE,          VIRTKEY, SHIFT
    VK_F6,          ID_NEXT_PANE,           VIRTKEY 
    VK_F6,          ID_PREV_PANE,           VIRTKEY, SHIFT
END


