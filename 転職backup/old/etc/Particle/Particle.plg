kernel32.lib user32.lib gdi32.lib winspool.lib comdlg32.lib advapi32.lib shell32.lib ole32.lib oleaut32.lib uuid.lib odbc32.lib odbccp32.lib /nologo /subsystem:windows /incremental:yes /pdb:"Debug/Particle.pdb" /debug /machine:I386 /out:"Debug/Particle.exe" /pdbtype:sept 
".\Debug\Particle.obj"
]
