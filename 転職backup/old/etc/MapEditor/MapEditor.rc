IDR_MAINFRAME MENUEX PRELOAD DISCARDABLE 
BEGIN
    POPUP "ﾌｧｲﾙ(&F)",                       65535,MFT_STRING,MFS_ENABLED
    BEGIN
        MENUITEM "サイズを指定してデータを作成(&M)", 32775,MFT_STRING,
        MFS_ENABLED
