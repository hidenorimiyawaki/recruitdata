        MENUITEM "中間ファイルを読み込む(&L)",  32785,MFT_STRING,MFS_ENABLED
        MENUITEM "中間ファイルを作成する(&O)",  32784,MFT_STRING,MFS_ENABLED
        MENUITEM MFT_SEPARATOR
        MENUITEM "マップデータをファイルに書き出す(&C)", 32774,MFT_STRING,
        MFS_ENABLED
        MENUITEM MFT_SEPARATOR
        MENUITEM "ｱﾌﾟﾘｹｰｼｮﾝの終了(&X)",         57665,MFT_STRING,MFS_ENABLED
    END
    POPUP "カーソル(&C)",                   65535,MFT_STRING,MFS_ENABLED
    BEGIN
        MENUITEM "サイズ指定(&S)",              32777,MFT_STRING,MFS_ENABLED
    END
    POPUP "BMP読み込み(&B)",                65535,MFT_STRING,MFS_ENABLED
    BEGIN
        MENUITEM "ロード(&L)",                  32776,MFT_STRING,MFS_ENABLED
    END
    POPUP "属性(&Z)",                       65535,MFT_STRING,MFS_ENABLED
    BEGIN
        MENUITEM "属性設定(&J)",                32786,MFT_STRING,MFS_ENABLED
    END
    POPUP "表示(&D)",                       65535,MFT_STRING,MFS_ENABLED
