/////////////////////////////////////////////////////////////////////////////
//
// Menu
//

IDR_MAINFRAME MENU 
BEGIN
    POPUP "ファイル(&F)"
    BEGIN
        MENUITEM "画像ファイルを開く",          ID_TEX_OPEN_1
        MENUITEM "新規作成\tCtrl+N(&N)",        ID_FILE_NEW
        MENUITEM "データファイルを開く.\tCtrl+O(&O)", ID_FILE_OPEN
        MENUITEM SEPARATOR
        MENUITEM "データファイルを閉じる(&C)",  ID_FILE_CLOSE
        MENUITEM "アプリケーションの終了(&X)",  ID_APP_EXIT
    END
    POPUP "表示(&V)"
    BEGIN
        MENUITEM "ツール バー(&T)",             ID_VIEW_TOOLBAR
    END
    POPUP "背景(&B)", INACTIVE
    BEGIN
        MENUITEM "色変更(&C)",                  ID_SET_COLOR_A
    END
    POPUP "ダイアログ(&D)"
    BEGIN
        MENUITEM "ステータス設定",              ID_SET_STATUS_A
        MENUITEM "テクスチャ設定",              ID_SET_TEXTURE_A
    END
    POPUP "ヘルプ(&H)"
    BEGIN
        MENUITEM "バージョン情報 test(&A)...",  ID_APP_ABOUT
    END
END

IDR_testTYPE MENU 
BEGIN
    POPUP "ファイル(&F)"
    BEGIN
        MENUITEM "画像ファイルを開く",          ID_TEX_OPEN_2
        MENUITEM "新規作成\tCtrl+N(&N)",        ID_FILE_NEW
        MENUITEM "データファイルを開く\tCtrl+O(&O)", ID_FILE_OPEN
        MENUITEM "データファイルを閉じる(&C)",  ID_FILE_CLOSE
        MENUITEM "上書き保存\tCtrl+S(&S)",      ID_FILE_SAVE
        MENUITEM "名前を付けて保存(&A)...",     ID_FILE_SAVE_AS
        MENUITEM SEPARATOR
        MENUITEM "アプリケーションの終了(&X)",  ID_APP_EXIT
    END
    POPUP "編集(&E)"
    BEGIN
        MENUITEM "元に戻す\tCtrl+Z(&U)",        ID_EDIT_UNDO
        MENUITEM SEPARATOR
        MENUITEM "切り取り\tCtrl+X(&T)",        ID_EDIT_CUT
        MENUITEM "コピー\tCtrl+C(&C)",          ID_EDIT_COPY
        MENUITEM "貼り付け\tCtrl+V(&P)",        ID_EDIT_PASTE
    END
    POPUP "表示(&V)"
    BEGIN
        MENUITEM "ツール バー(&T)",             ID_VIEW_TOOLBAR
    END
    POPUP "背景(&B)"
    BEGIN
        MENUITEM "色変更(&C)",                  ID_SET_COLOR_B
    END
    POPUP "ダイアログ(&D)"
    BEGIN
        MENUITEM "ステータス設定",              ID_SET_STATUS_B
        MENUITEM "テクスチャ設定",              ID_SET_TEXTURE_B
    END
    POPUP "ウィンドウ(&W)", INACTIVE
    BEGIN
        MENUITEM "新しいウィンドウを開く(&N)",  ID_WINDOW_NEW
        MENUITEM "重ねて表示(&C)",              ID_WINDOW_CASCADE
        MENUITEM "並べて表示(&T)",              ID_WINDOW_TILE_HORZ
        MENUITEM "アイコンの整列(&A)",          ID_WINDOW_ARRANGE
    END
    POPUP "ヘルプ(&H)"
    BEGIN
        MENUITEM "バージョン情報 test(&A)...",  ID_APP_ABOUT
    END
END


