//*********************************************************S
//					メインエントリ
//
// 起動・初期化後、この関数よりプログラム実行が始まります
//
int main(void)
{
  int	i;
  

	ClearRamAll();	// ＲＡＭクリア（メモリへのアクセスウェイトも設定しています）
	InitVBlank();	// Vブランク初期化
	InitHardware();	// ＯＢＪ・ＢＧの設定などを行っています、詳しくは hard_init.c 参照
	
	//**************** ＯＢＪ表示のための準備 *****************S
	for( i=0 ; i<128 ; i++ ){
		oam_buffer[i].attr0 = 0x0200;
		oam_buffer[i].attr1 = oam_buffer[i].attr2 = oam_buffer[i].rot_para = 0;
	}

	DmaArrayCopy( 3, hero_stand_1_Palette, OBJ_PLTT, 16 );
	DmaArrayCopy( 3, hero_stand_1_Char, OBJ_MODE0_VRAM, 16 );

	DmaArrayCopy( 3, hero_stand_2_Palette, OBJ_PLTT, 16 );
	DmaArrayCopy( 3, hero_stand_2_Char, OBJ_MODE0_VRAM+32*16, 16 );
	
	
	
	oam_buffer[0].attr0 = OAM_SQUARE | OAM_COLOR_16 | OAM_AFFINE_NONE | OAM_MOS_OFF | y_pos;
	oam_buffer[0].attr1 = (OAM_SIZE_32x32 >> 16) | x_pos;
	oam_buffer[0].attr2 = hero_spright;

	
	DmaCopy(3, oam_buffer, OAM, 1024 , 32);		// ＯＡＭデータを転送します
	//**************** ＯＢＪ表示のための準備 *****************E



	
	while(1){		// ←ゲームループ
		

		V_Wait();	// V-Blank割り込みが発生し、登録関数を処理するまで待ちます
	}
	return	0;		// ゲームプログラムがここに来ることはありません
}
//*********************************************************E



//**********************************************************S
//						キーマネージャ
//
// フレーム毎にこの関数を呼ぶことで、キー入力状態がセットされる
//
void KeyManager(void)
{
	oldKey = nowKey;							// 前回のキー内容の退避
	nowKey = (*(vu16 *)REG_KEYINPUT ^ 0x03ff);	// 今回のキー内容の取得
}
//*********************************************************E


