const ANIME_TABLE spright_anime00[]={
		{ 0x0000, 0, 0,  8, 0x0 },
		{ 0x0010, 0, 0,  6, 0x1 },
		{ 0x0000, 0, 0,  8, 0x2 },
		{ 0x0010, 0, 0,  6, 0x3 },
		{ 0x0000, 0, 0,  16, 0x4 },
		{ 0x0010, 0, 0,  6, 0x5 },
		{ 0x0000, 0, 0,  4, 0x6 },
		{ 0x0010, 0, 0,  6, 0x7 },
		{ 0xeded, 0, 0, 0,0xed }
};
//***************************** 宣言 ******************************E


u16	x_pos,y_pos;
u16	hero_spright = 0x0000;
const ANIME_TABLE	*p_table;

	x_pos = y_pos = 50;
	p_table = spright_anime00;
	

void	KeyManager(void);	//60分の1秒にキーを取得する関数
int		hero_anime(ANIME_TABLE anime);	//とりあえず瞬きするプログラム
