#include <agb.h>
#include "hard_init.h"

//******************************** 初期化関連 *********************************S
//*********************************************************S
//	全ＲＡＭ領域の初期化
void ClearRamAll( void )
{
	// プログラム実行開始時にはウェイトコントロール設定値が 000 に初期化されています。
	// 使用しているＲＯＭに適したウェイトを一度だけセットします。
	// 3-1ウェイトアクセス設定
	*(vu16 *)REG_WAITCNT = CST_ROM0_1ST_3WAIT | CST_ROM0_2ND_1WAIT | CST_PREFETCH_ENABLE;
	ClearWorkRam();
	ClearGraphicRam();
}
//*********************************************************E

//*********************************************************S
//	ワークＲＡＭの初期化
void ClearWorkRam( void )
{
	DmaClear(3, 0, EX_WRAM,  EX_WRAM_SIZE,          32);	// CPU外部ワークRAM クリア
	DmaClear(3, 0, CPU_WRAM, CPU_WRAM_SIZE - 0x200, 32);	// CPU内部ワークRAM クリア
}
//*********************************************************E

//*********************************************************S
//	グラフィック関係のRAM初期化
void ClearGraphicRam( void )
{
	ClearVram();
	ClearOamRam();
	ClearPaletteRam();
}
//*********************************************************E

//*********************************************************S
//	ＶＲＡＭの初期化
void ClearVram( void )
{
	DmaClear(3, 0, VRAM, VRAM_SIZE, 16);
}
//*********************************************************E

//*********************************************************S
//	ＯＡＭの初期化
void ClearOamRam( void )
{
  int	i=0;
  u16	*oam_ptr;
	oam_ptr = (u16*)OAM;
	for( i=0 ; i<32 ; ++i )
	{
		*oam_ptr++ = 0x0200;
		*oam_ptr++ = 0x0000;
		*oam_ptr++ = 0x0000;
		*oam_ptr++ = 0x0100;
		*oam_ptr++ = 0x0200;
		*oam_ptr++ = 0x0000;
		*oam_ptr++ = 0x0000;
		*oam_ptr++ = 0x0000;
		*oam_ptr++ = 0x0200;
		*oam_ptr++ = 0x0000;
		*oam_ptr++ = 0x0000;
		*oam_ptr++ = 0x0000;
		*oam_ptr++ = 0x0200;
		*oam_ptr++ = 0x0000;
		*oam_ptr++ = 0x0000;
		*oam_ptr++ = 0x0100;
	}
}
//*********************************************************E

//*********************************************************S
//	パレットVRAM初期化
void ClearPaletteRam( void )
{
	DmaClear(3, 0, PLTT, PLTT_SIZE, 16);
}
//*********************************************************E

//*********************************************************S
//	ハードウェアの初期化
void InitHardware( void )
{
	*(vu16 *)REG_IE   = CASSETTE_INTR_FLAG;     // カートリッジ割込許可
	*(vu16 *)REG_IME  = 1;                      // 割り込みマスタイネーブル（割り込み全体のマスクOFF）
	*(vu16 *)REG_STAT = STAT_V_BLANK_IF_ENABLE;	// Vブランク割込要求フラグ・セット許可
	
	/************** スプライト・ＢＧのモード設定 ************S*/
	*(vu16 *)REG_IE |= V_BLANK_INTR_FLAG;				// V-Blank割り込み許可
						//  BGモード0     OBJ表示ON     BG0表示ON    一次元オブジェフォーマット
	*(vu16 *)REG_DISPCNT = DISP_MODE_0 | DISP_OBJ_ON | DISP_BG0_ON | DISP_BG1_ON | DISP_OBJ_CHAR_1D_MAP;
	/************** スプライト・ＢＧのモード設定 ************E*/
}
//*********************************************************E
//******************************** 初期化関連 *********************************E




//************** 割り込み関連のプロトタイプ ***************S
extern void	intr_main(void);	// リセットエントりー
void		VBlankFunc(void);	// 登録した関数を呼び出す
void		dummy(void);
//************** 割り込み関連のプロトタイプ ***************E

//***************** 割り込み処理用の変数 ******************S
vu16		IntrCheck;				// 割り込みチェックフラグ
u32			IntrMainBuf[0x200];		// 割り込みメインルーチン用バッファ
IntrFuncp	v_blank_fnc;			// 関数ポインタ

const IntrFuncp IntrTable[14] =
{
	VBlankFunc,
	dummy,dummy,dummy,dummy,
	dummy,dummy,dummy,dummy,
	dummy,dummy,dummy,dummy,
	dummy,
};
//***************** 割り込み処理用の変数 ******************E

//*********************************************************S
//	割り込み関数初期化
void InitVBlank( void )
{
    V_Intr_Clear();
    v_blank_fnc = dummy;
    DmaCopy(3, intr_main, IntrMainBuf, sizeof(IntrMainBuf), 16);
    IntrAddrSet(IntrMainBuf);
}
//*********************************************************E

//*********************************************************S
//	Ｖブランク関数登録
void SetVBlankFunc( IntrFuncp fnc )
{
    v_blank_fnc = ( (void*)0 != fnc ) ? fnc : dummy;
}
//*********************************************************E

//*********************************************************S
//	Ｖブランク関数実行
void VBlankFunc( void )
{
    if( (void*)0 != v_blank_fnc )	(*v_blank_fnc)();
    V_Intr_Set();
}
//*********************************************************E

//*********************************************************S
//	割り込みダミー関数
void dummy(void)
{}
//*********************************************************E

//*********************************************************S
//	Ｖブランク割込チェックフラグのクリア
void V_Intr_Clear(void)
{
    IntrCheck &= V_BLANK_INTR_FLAG ^ 0xffff;
}
//*********************************************************E

//*********************************************************S
//	Ｖブランク割込チェックフラグのセット
void V_Intr_Set(void)
{
    *(vu16 *)REG_IF	= V_BLANK_INTR_FLAG;
    IntrCheck		= V_BLANK_INTR_FLAG;
}
//*********************************************************E

//*********************************************************S
//	Ｖブランク関数終了待ち
void V_Wait(void)
{
	V_Intr_Clear();
	while(1){
		Halt();		// CPU停止
		if(IntrCheck & V_BLANK_INTR_FLAG)	break;	// Vブランク割込処理 終了
	}
}
//*********************************************************E

